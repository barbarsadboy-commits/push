rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is superadmin (Developer)
    function isSuperAdmin() {
      return isAuthenticated() && 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'dev');
    }

    // Helper function to check if user is reseller
    function isReseller() {
      return isAuthenticated() && 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'reseller' || 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'resseler'));
    }

    // Tokens Collection (VIP Upgrade Tokens)
    match /tokens/{tokenId} {
      // Superadmin can do everything
      allow read, write: if isSuperAdmin();
      // Others can read/update if they know the token ID (which is the code)
      // and only to decrement the usage count
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && 
        request.resource.data.usageCount == resource.data.usageCount - 1 &&
        request.resource.data.usageCount >= 0;
    }

    // Users Collection
    match /users/{userId} {
      // User can read their own profile
      allow read: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin() || isReseller());
      // User can create their own profile
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // User can update their own profile (except role)
      allow update: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin() || isReseller());
      // Only superadmin can delete users
      allow delete: if isSuperAdmin();
    }

    // Settings Collection (Pricing, Limits, System Config)
    match /settings/{document=**} {
      // Allow public read for pricing (Landing Page needs this)
      allow read: if true;
      // Only superadmin can write settings
      allow write: if isSuperAdmin();
    }

    // Websites Collection (Website Builder)
    match /websites/{siteId} {
      // Allow public read (so deployed sites can fetch their config if needed)
      allow read: if true;
      // Allow authenticated users to create/update their sites
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isSuperAdmin());
    }

    // Linktrees Collection
    match /linktrees/{linkId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isSuperAdmin());
    }

    // Payments Collection
    match /payments/{paymentId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isSuperAdmin());
    }

    // Testimonials Collection
    match /testimonials/{testiId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isSuperAdmin());
    }

    // Default catch-all (Secure by default)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
